# ==============================================================================
# Git Ignore Configuration for Visitor Management System
# ==============================================================================

# ------------------------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ------------------------------------------------------------------------------
# IDEs and Editors
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Python (Backend)
# ------------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
ENV/
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# Node / Frontend / Build Artefacts
# ------------------------------------------------------------------------------
node_modules/
dist/
build/
out/
.next/
.nuxt/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# Project Specific (Sensitive Data, Uploads, DB Backups)
# ------------------------------------------------------------------------------
# Environment files (contains credentials, API keys, bot tokens, etc.)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
.env.example

# Dynamic medi
backend/uploads/*
!backend/uploads/.gitkeep

# Database dumps, raw SQL files, and SQLite databases
*.sql
*.dump
database/backups/*
!database/backups/.gitkeep
*.db
*.sqlite
*.sqlite3
